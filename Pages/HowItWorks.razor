            </circle>
            <circle class="data-particle particle-4" r="2" fill="#a44aff" filter="url(#glow)">
                <animateMotion dur="4s" repeatCount="indefinite" begin="2s" path="M 280,232 L 280,302 L 440,370" />
            </circle>

