@page "/how-it-works"

<PageTitle>How It Works</PageTitle>

<section class="home how-it-works">
    <p class="status">architecture</p>
    <h1>How It Works</h1>
    <p class="tagline">How a request reaches this page from home.pefi.co.uk</p>

    <div class="architecture-flow">
        <div class="flow-step">
            <div class="step-number">1</div>
            <h2>DNS Resolution</h2>
            <p>
                Your browser looks up <strong>home.pefi.co.uk</strong>. DNSimple returns a
                CNAME record pointing to the dynamic A record for pefi.co.uk, which resolves
                to the public IP of the home network. The
                <a href="https://github.com/petefield/pefi.dynamicdns" target="_blank">pefi.dynamicdns</a>
                service keeps this A record up to date by polling the public IP every two minutes
                and pushing changes to DNSimple.
            </p>
        </div>

        <div class="flow-connector"></div>

        <div class="flow-step">
            <div class="step-number">2</div>
            <h2>Reverse Proxy</h2>
            <p>
                The request arrives at the home network and hits
                <a href="https://github.com/petefield/pefi.proxy" target="_blank">pefi.proxy</a>,
                a .NET 9 reverse proxy built on YARP. It inspects the <code>Host</code> header
                (<code>home.pefi.co.uk</code>) and matches it against its route table. Routes are
                configured both statically and dynamically &mdash; a background service listens for
                RabbitMQ events from the Service Manager so new services are routable the moment
                they start, with zero downtime.
            </p>
        </div>

        <div class="flow-connector"></div>

        <div class="flow-step">
            <div class="step-number">3</div>
            <h2>This Page</h2>
            <p>
                The proxy forwards the request to
                <a href="https://github.com/petefield/pefi.homepage" target="_blank">pefi.homepage</a>,
                a Blazor WebAssembly app running in a Docker container. The static assets are served
                to your browser, and from that point Blazor handles all routing client-side &mdash;
                including the navigation to this page.
            </p>
        </div>
    </div>

    <div class="architecture-diagram">
        <svg viewBox="0 0 560 420" xmlns="http://www.w3.org/2000/svg" class="arch-svg">
            <defs>
                <filter id="glow">
                    <feGaussianBlur stdDeviation="3" result="blur" />
                    <feMerge>
                        <feMergeNode in="blur" />
                        <feMergeNode in="SourceGraphic" />
                    </feMerge>
                </filter>
                <filter id="glow-strong">
                    <feGaussianBlur stdDeviation="6" result="blur" />
                    <feMerge>
                        <feMergeNode in="blur" />
                        <feMergeNode in="SourceGraphic" />
                    </feMerge>
                </filter>
                <linearGradient id="line-grad" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="#76ffe8" stop-opacity="0.8" />
                    <stop offset="100%" stop-color="#5fc2ff" stop-opacity="0.4" />
                </linearGradient>
                <linearGradient id="node-fill" x1="0" y1="0" x2="1" y2="1">
                    <stop offset="0%" stop-color="rgba(4, 9, 30, 0.9)" />
                    <stop offset="100%" stop-color="rgba(5, 20, 44, 0.7)" />
                </linearGradient>
                <radialGradient id="pulse-grad" cx="50%" cy="50%" r="50%">
                    <stop offset="0%" stop-color="#00ffe1" stop-opacity="0.3" />
                    <stop offset="100%" stop-color="#00ffe1" stop-opacity="0" />
                </radialGradient>
            </defs>

            <!-- Animated data particles along the main path -->
            <circle class="data-particle particle-1" r="3" fill="#76ffe8" filter="url(#glow)">
                <animateMotion dur="3s" repeatCount="indefinite" path="M 280,52 L 280,102 L 280,162 L 280,232 L 280,302" />
            </circle>
            <circle class="data-particle particle-2" r="2" fill="#5fc2ff" filter="url(#glow)">
                <animateMotion dur="3s" repeatCount="indefinite" begin="1s" path="M 280,52 L 280,102 L 280,162 L 280,232 L 280,302" />
            </circle>
            <circle class="data-particle particle-3" r="2" fill="#a44aff" filter="url(#glow)">
