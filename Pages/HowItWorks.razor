                <text x="280" y="37" text-anchor="middle" fill="#cbf8ff" font-size="13" font-family="Inter, sans-serif">Browser</text>
            </g>

            <!-- DNS node -->
            <g class="node">
                <rect x="200" y="102" width="160" height="50" rx="8" fill="url(#node-fill)" stroke="#5fc2ff" stroke-width="1.5" filter="url(#glow)" />
                <text x="280" y="124" text-anchor="middle" fill="#76ffe8" font-size="11" font-family="Inter, sans-serif" font-weight="600">DNSimple</text>
                <text x="280" y="141" text-anchor="middle" fill="#b0d7f8" font-size="10" font-family="Inter, sans-serif">home.pefi.co.uk</text>
            </g>

            <!-- DynDNS node (side) -->
