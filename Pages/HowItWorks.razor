                    <animate attributeName="opacity" values="0.3;1;0.3" dur="2s" repeatCount="indefinite" />
                </circle>
            </g>

            <!-- Home IP node -->
            <g class="node">
                <rect x="210" y="172" width="140" height="50" rx="8" fill="url(#node-fill)" stroke="#76ffe8" stroke-width="1.5" filter="url(#glow)" />
                <text x="280" y="194" text-anchor="middle" fill="#76ffe8" font-size="11" font-family="Inter, sans-serif" font-weight="600">Home Network</text>
                <text x="280" y="211" text-anchor="middle" fill="#b0d7f8" font-size="10" font-family="Inter, sans-serif">Public IP</text>
                <!-- Animated ring -->
                <circle cx="280" cy="197" r="28" fill="none" stroke="#76ffe8" stroke-width="0.5" opacity="0.2">
                    <animate attributeName="r" values="28;34;28" dur="3s" repeatCount="indefinite" />
                    <animate attributeName="opacity" values="0.2;0;0.2" dur="3s" repeatCount="indefinite" />
                </circle>
            </g>

            <!-- Proxy node -->
            <g class="node">
                <rect x="200" y="242" width="160" height="50" rx="8" fill="url(#node-fill)" stroke="#5fc2ff" stroke-width="1.5" filter="url(#glow)" />
                <text x="280" y="264" text-anchor="middle" fill="#5fc2ff" font-size="11" font-family="Inter, sans-serif" font-weight="600">pefi.proxy</text>
                <text x="280" y="281" text-anchor="middle" fill="#b0d7f8" font-size="10" font-family="Inter, sans-serif">YARP Reverse Proxy</text>
            </g>

            <!-- Router hub -->
            <circle cx="280" cy="327" r="10" fill="url(#node-fill)" stroke="#5fc2ff" stroke-width="1" filter="url(#glow)" />
            <circle cx="280" cy="327" r="3" fill="#5fc2ff" filter="url(#glow-strong)">
                <animate attributeName="r" values="2;4;2" dur="2s" repeatCount="indefinite" />
            </circle>

            <!-- Service A -->
            <g class="node">
                <rect x="60" y="370" width="120" height="40" rx="8" fill="url(#node-fill)" stroke="rgba(0,255,255,0.3)" stroke-width="1" filter="url(#glow)" opacity="0.7" />
                <text x="120" y="394" text-anchor="middle" fill="#b0d7f8" font-size="10" font-family="Inter, sans-serif">service A</text>
            </g>

            <!-- Homepage (highlighted) -->
            <g class="node node-active">
                <rect x="215" y="370" width="130" height="40" rx="8" fill="url(#node-fill)" stroke="#76ffe8" stroke-width="2" filter="url(#glow-strong)" />
                <text x="280" y="394" text-anchor="middle" fill="#76ffe8" font-size="11" font-family="Inter, sans-serif" font-weight="600">homepage</text>
                <!-- Active glow ring -->
                <circle cx="280" cy="390" r="24" fill="none" stroke="#76ffe8" stroke-width="0.8" opacity="0.15">
                    <animate attributeName="r" values="24;32;24" dur="2.5s" repeatCount="indefinite" />
                    <animate attributeName="opacity" values="0.15;0;0.15" dur="2.5s" repeatCount="indefinite" />
                </circle>
            </g>

            <!-- Service B -->
            <g class="node">
                <rect x="380" y="370" width="120" height="40" rx="8" fill="url(#node-fill)" stroke="rgba(0,255,255,0.3)" stroke-width="1" filter="url(#glow)" opacity="0.7" />
                <text x="440" y="394" text-anchor="middle" fill="#b0d7f8" font-size="10" font-family="Inter, sans-serif">service B</text>
            </g>

            <!-- DynDNS to DNSimple connection -->
            <line x1="510" y1="192" x2="510" y2="220" stroke="#a44aff" stroke-width="1" stroke-dasharray="4 3" filter="url(#glow)" opacity="0.4" />
        </svg>
    </div>

    <div class="flow-step summary">
        <h2>Dynamic DNS</h2>
        <p>
            The <strong>pefi.dynamicdns</strong> microservice runs alongside everything else. It does two things:
            it polls the public IP and updates the A record when it changes, and it listens on RabbitMQ for
            service lifecycle events. When a new service is deployed, it automatically creates a CNAME record
            so <code>&lt;service&gt;.pefi.co.uk</code> resolves without any manual DNS configuration.
        </p>
    </div>

    <a class="nav-link" href="/">Back to Home</a>
</section>
