            <line x1="280" y1="52" x2="280" y2="102" stroke="url(#line-grad)" stroke-width="2" filter="url(#glow)" class="conn-line" />
            <line x1="280" y1="152" x2="280" y2="172" stroke="url(#line-grad)" stroke-width="2" filter="url(#glow)" class="conn-line" />
            <line x1="280" y1="222" x2="280" y2="242" stroke="url(#line-grad)" stroke-width="2" filter="url(#glow)" class="conn-line" />
            <line x1="280" y1="292" x2="280" y2="312" stroke="url(#line-grad)" stroke-width="2" filter="url(#glow)" class="conn-line" />

            <!-- Fan-out lines from proxy to services -->
            <line x1="280" y1="342" x2="120" y2="370" stroke="url(#line-grad)" stroke-width="1.5" filter="url(#glow)" class="conn-line" />
            <line x1="280" y1="342" x2="280" y2="370" stroke="url(#line-grad)" stroke-width="2" filter="url(#glow)" class="conn-line" />
            <line x1="280" y1="342" x2="440" y2="370" stroke="url(#line-grad)" stroke-width="1.5" filter="url(#glow)" class="conn-line" />

            <!-- DynDNS side connection -->
            <line x1="380" y1="127" x2="460" y2="127" stroke="#a44aff" stroke-width="1.5" stroke-dasharray="4 3" filter="url(#glow)" opacity="0.6" class="conn-line" />
            <line x1="510" y1="147" x2="510" y2="172" stroke="#a44aff" stroke-width="1.5" stroke-dasharray="4 3" filter="url(#glow)" opacity="0.6" class="conn-line" />

            <!-- Browser node -->
            <g class="node">
