                <rect x="460" y="102" width="100" height="45" rx="8" fill="url(#node-fill)" stroke="#a44aff" stroke-width="1.2" filter="url(#glow)" opacity="0.8" />
                <text x="510" y="121" text-anchor="middle" fill="#a44aff" font-size="10" font-family="Inter, sans-serif" font-weight="600">dynamicdns</text>
                <text x="510" y="136" text-anchor="middle" fill="#b0d7f8" font-size="9" font-family="Inter, sans-serif">IP monitor</text>
                <!-- Pulsing indicator -->
